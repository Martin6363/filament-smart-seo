{
    "name": "martin6363/filament-smart-seo",
    "description": "AI-powered SEO auditor, autofill, and live Google SERP preview for Filament v5",
    "keywords": [
        "laravel",
        "filament",
        "plugin",
        "seo",
        "gemini",
        "spatie-translatable"
    ],
    "homepage": "https://github.com/martin6363/filament-smart-seo",
    "license": "MIT",
    "authors": [
        {
            "name": "Martin",
            "email": "martin.khachatryan.2024@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "filament/filament": "^4.0|^5.0",
        "google-gemini-php/client": "^2.0",
        "spatie/laravel-translatable": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Martin6363\\FilamentSmartSeo\\": "src/"
        }
    },
    "extra": {
        "laravel": {
